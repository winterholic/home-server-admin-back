# ============================================
# HomeServer Dashboard Backend Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- Database (MariaDB) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=nodectrl

# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
SECRET_KEY=change-this-to-a-random-secret-key

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your_email@gmail.com
SMTP_TLS=true

# --- Monitoring ---
# Data collection interval in seconds (default: 300 = 5 minutes)
MONITOR_INTERVAL=300
# Data retention in days (default: 30)
DATA_RETENTION_DAYS=30

# --- Service Management ---
# Comma-separated list of systemd services to monitor
SYSTEMD_SERVICES=nginx,mariadb,redis-server,cloudflared

# Comma-separated list of Docker container names/IDs to monitor
# Leave empty to auto-discover all running containers
DOCKER_CONTAINERS=

# Comma-separated nohup process identifiers (process name or command keyword)
# Example: NOHUP_SERVICES=ariari-app:java -jar ariari.jar,my-bot:python bot.py
# Format: display_name:process_keyword
NOHUP_SERVICES=

# --- Log Paths ---
NGINX_ACCESS_LOG=/var/log/nginx/access.log
NGINX_ERROR_LOG=/var/log/nginx/error.log
AUTH_LOG=/var/log/auth.log
SYSLOG=/var/log/syslog
